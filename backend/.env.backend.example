# ===============================================
# FRAPPE LMS BACKEND CONFIGURATION (Render Docker)
# ===============================================

# Port Render binds the HTTP routing to (automatically set by Render)
PORT=8000

# The base URL of your deployed frontend (Vercel URL, used for CORS configuration)
FRONTEND_URL="https://vyomanta.vercel.app"

# Remote MySQL/MariaDB database details for Frappe persistence
DB_HOST="gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com"
DB_PORT="4000"
DB_USER="your-database-user-string"
DB_PASSWORD="your-database-password"
DB_NAME="your-frappe-db-name"

# Administrator user password for the Frappe Admin Workspace dashboard
ADMIN_PASSWORD="admin"
